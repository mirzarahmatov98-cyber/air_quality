# Google Earth Engine Credentials
# Download your service account JSON from Google Cloud Console
GEE_CREDENTIALS=path/to/service-account-key.json

# Google Cloud Storage
GCS_BUCKET=air-quality-uzbekistan-data
GCS_PROJECT_ID=your-gcp-project-id

# Application Settings
DEBUG=False
LOG_LEVEL=INFO

# Database (optional)
DATABASE_URL=sqlite:///data/air_quality.db
